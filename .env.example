# ═══════════════════════════════════════════════════════════════════════════════
# ARIA X — Environment Configuration
# Copy this file to .env and fill in your keys.
# NEVER commit the real .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ARIA X
VERSION=2.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING_MINIMUM

# CORS — add your frontend URL in production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── AI Providers (at least one required) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...

# AI Models
PRIMARY_MODEL=gpt-4o
FALLBACK_MODEL=claude-sonnet-4-20250514
VISION_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large

# ── Voice ─────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL    # Bella — warm female voice
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Azure Neural TTS (fallback)
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus

# Wake word detection
ENABLE_WAKE_WORD=true
WAKE_WORDS=["hey aria","aria","assistant"]
VOICE_TIMEOUT=5

# ── Databases ─────────────────────────────────────────────────────────────────
# SQLite (dev — auto-created)
DATABASE_URL=sqlite+aiosqlite:///./data/aria.db

# PostgreSQL (production — overrides SQLite)
# POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/aria_db

# Redis (session cache, rate limiting)
REDIS_URL=redis://localhost:6379/0

# Vector stores
CHROMA_PERSIST_DIR=./data/embeddings/chroma
FAISS_INDEX_DIR=./data/embeddings/faiss

# ── Memory ────────────────────────────────────────────────────────────────────
MAX_SHORT_TERM_MESSAGES=20
LONG_TERM_MEMORY_LIMIT=10000
MEMORY_RELEVANCE_THRESHOLD=0.72

# ── Security ──────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080          # 7 days
BCRYPT_ROUNDS=12
# ENCRYPTION_KEY=                 # Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Features ──────────────────────────────────────────────────────────────────
ENABLE_EMOTION_DETECTION=true
ENABLE_COMPUTER_VISION=true
ENABLE_COMPUTER_CONTROL=false     # requires explicit user consent
ENABLE_EMAIL_AGENT=false          # configure SMTP before enabling
ENABLE_CALENDAR_AGENT=false       # configure calendar API before enabling

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# SENTRY_DSN=https://...@sentry.io/...
PROMETHEUS_PORT=9090
